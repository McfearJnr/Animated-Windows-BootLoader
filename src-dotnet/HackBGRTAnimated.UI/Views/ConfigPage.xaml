<UserControl x:Class="HackBGRTAnimated.UI.Views.ConfigPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Config" FontSize="30" FontWeight="Bold"/>
            <TextBlock x:Name="ActiveThemeText" Margin="0,4,0,12"/>

            <WrapPanel Margin="0,4,0,8">
                <TextBlock Text="FPS:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox x:Name="FpsBox" Width="80" Margin="0,0,12,0"/>
                <TextBlock Text="Max duration ms:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox x:Name="MaxMsBox" Width="100" Margin="0,0,12,0"/>
            </WrapPanel>

            <WrapPanel Margin="0,0,0,8">
                <CheckBox x:Name="PreloadCheck" Content="Preload frames" Margin="0,0,12,0"/>
                <CheckBox x:Name="ClearCheck" Content="Clear each frame"/>
            </WrapPanel>

            <WrapPanel Margin="0,0,0,8">
                <TextBlock Text="Panic key:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox x:Name="PanicKeyCombo" Width="120">
                    <ComboBoxItem Content="esc"/>
                    <ComboBoxItem Content="space"/>
                    <ComboBoxItem Content="none"/>
                </ComboBox>
            </WrapPanel>

            <WrapPanel>
                <Button Content="Save" Margin="4" Click="Save_OnClick"/>
                <Button Content="Set Fallback Splash Image" Margin="4" Click="SetSplash_OnClick"/>
                <Button Content="Refresh" Margin="4" Click="Refresh_OnClick"/>
            </WrapPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
