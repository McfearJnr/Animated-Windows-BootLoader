<UserControl x:Class="HackBGRTAnimated.UI.Views.ImportGifPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             AllowDrop="True"
             Drop="OnDropGif">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Import GIF" FontSize="30" FontWeight="Bold"/>
            <TextBlock Text="Select a GIF and convert it to BMP frames for UEFI playback." Margin="0,4,0,12"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="GIF file:" VerticalAlignment="Center"/>
                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                    <TextBox x:Name="GifPathBox" Width="540" Margin="0,0,8,0"/>
                    <Button Content="Browse" Click="Browse_OnClick"/>
                </StackPanel>

                <TextBlock Grid.Row="1" Text="Theme name:" VerticalAlignment="Center"/>
                <TextBox Grid.Row="1" Grid.Column="1" x:Name="ThemeNameBox" Width="260"/>

                <TextBlock Grid.Row="2" Text="Output width:" VerticalAlignment="Center"/>
                <TextBox Grid.Row="2" Grid.Column="1" x:Name="WidthBox" Width="100" Text="400"/>

                <TextBlock Grid.Row="3" Text="Output height:" VerticalAlignment="Center"/>
                <TextBox Grid.Row="3" Grid.Column="1" x:Name="HeightBox" Width="100" Text="400"/>

                <TextBlock Grid.Row="4" Text="FPS:" VerticalAlignment="Center"/>
                <TextBox Grid.Row="4" Grid.Column="1" x:Name="FpsBox" Width="100" Text="15"/>

                <TextBlock Grid.Row="5" Text="Max duration (ms):" VerticalAlignment="Center"/>
                <TextBox Grid.Row="5" Grid.Column="1" x:Name="MaxMsBox" Width="120" Text="3000"/>

                <TextBlock Grid.Row="6" Text="Background (RRGGBB):" VerticalAlignment="Center"/>
                <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal">
                    <TextBox x:Name="BackgroundBox" Width="100" Text="000000"/>
                    <CheckBox x:Name="SetActiveCheck" IsChecked="True" Content="Set active after import" Margin="16,0,0,0"/>
                </StackPanel>
            </Grid>

            <WrapPanel Margin="0,12,0,12">
                <Button Content="Import" Margin="4" Click="Import_OnClick"/>
                <Button Content="Preview Theme Folder" Margin="4" Click="Preview_OnClick"/>
            </WrapPanel>

            <TextBox x:Name="ProgressBox" Height="260" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" IsReadOnly="True"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
