<UserControl x:Class="HackBGRTAnimated.UI.Views.ThemesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Themes" FontSize="30" FontWeight="Bold"/>
            <TextBlock x:Name="ActiveThemeText" Margin="0,4,0,4"/>
            <TextBlock x:Name="ThemesPathText" Margin="0,0,0,12" TextWrapping="Wrap"/>
        </StackPanel>

        <ListView Grid.Row="1" x:Name="ThemeList">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Name}" Width="200"/>
                    <GridViewColumn Header="FPS" DisplayMemberBinding="{Binding AnimationFps}" Width="80"/>
                    <GridViewColumn Header="Duration (ms)" DisplayMemberBinding="{Binding AnimationMaxMs}" Width="110"/>
                    <GridViewColumn Header="Frames" DisplayMemberBinding="{Binding FrameCount}" Width="90"/>
                    <GridViewColumn Header="Size (KB)" DisplayMemberBinding="{Binding EstimatedBytes}" Width="120"/>
                </GridView>
            </ListView.View>
        </ListView>

        <WrapPanel Grid.Row="2" Margin="0,12,0,0">
            <Button Content="Refresh" Margin="4" Click="Refresh_OnClick"/>
            <Button Content="Set Active" Margin="4" Click="SetActive_OnClick"/>
            <Button Content="Edit FPS/Duration" Margin="4" Click="EditTiming_OnClick"/>
            <Button Content="Delete Theme" Margin="4" Click="DeleteTheme_OnClick"/>
            <Button Content="Preview" Margin="4" Click="Preview_OnClick"/>
            <Button Content="Open Theme Folder" Margin="4" Click="OpenFolder_OnClick"/>
            <Button Content="Open Themes Folder" Margin="4" Click="OpenThemesFolder_OnClick"/>
            <Button Content="Export Theme" Margin="4" Click="ExportTheme_OnClick"/>
            <Button Content="Import Theme" Margin="4" Click="ImportTheme_OnClick"/>
        </WrapPanel>
    </Grid>
</UserControl>
