<UserControl x:Class="HackBGRTAnimated.UI.Views.AdvancedPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock Text="Advanced" FontSize="30" FontWeight="Bold"/>
        <TextBlock Text="These are legacy HackBGRT tools. Use with caution." Margin="0,8,0,12"/>
        <WrapPanel>
            <Button Content="Launch legacy setup.exe" Margin="4" Click="LaunchLegacy_OnClick"/>
            <Button Content="Open repository folder" Margin="4" Click="OpenRepo_OnClick"/>
        </WrapPanel>
    </StackPanel>
</UserControl>
