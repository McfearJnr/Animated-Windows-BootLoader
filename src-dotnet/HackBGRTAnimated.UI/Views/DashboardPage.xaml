<UserControl x:Class="HackBGRTAnimated.UI.Views.DashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Dashboard" FontSize="30" FontWeight="Bold"/>
            <TextBlock Text="Manage HackBGRT-Animated install and boot entry state." Margin="0,4,0,12"/>

            <Border Background="White" CornerRadius="10" Padding="14" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Installed:" Grid.Row="0"/>
                    <TextBlock x:Name="InstalledText" Grid.Row="0" Grid.Column="1"/>
                    <TextBlock Text="EFI folder:" Grid.Row="1"/>
                    <TextBlock x:Name="EfiFolderText" Grid.Row="1" Grid.Column="1"/>
                    <TextBlock Text="Boot entry:" Grid.Row="2"/>
                    <TextBlock x:Name="BootEntryText" Grid.Row="2" Grid.Column="1"/>
                    <TextBlock Text="In boot order:" Grid.Row="3"/>
                    <TextBlock x:Name="BootOrderText" Grid.Row="3" Grid.Column="1"/>
                    <TextBlock Text="Default:" Grid.Row="4"/>
                    <TextBlock x:Name="DefaultText" Grid.Row="4" Grid.Column="1"/>
                    <TextBlock Text="Active theme:" Grid.Row="5"/>
                    <TextBlock x:Name="ActiveThemeText" Grid.Row="5" Grid.Column="1"/>
                    <TextBlock Text="EFI path:" Grid.Row="6"/>
                    <TextBlock x:Name="EfiPathText" Grid.Row="6" Grid.Column="1" TextWrapping="Wrap"/>
                    <TextBlock Text="AppData root:" Grid.Row="7"/>
                    <TextBlock x:Name="AppDataText" Grid.Row="7" Grid.Column="1" TextWrapping="Wrap"/>
                    <TextBlock Text="Themes folder:" Grid.Row="8"/>
                    <TextBlock x:Name="ThemesPathText" Grid.Row="8" Grid.Column="1" TextWrapping="Wrap"/>
                    <TextBlock Text="Admin:" Grid.Row="9"/>
                    <TextBlock x:Name="AdminText" Grid.Row="9" Grid.Column="1"/>
                </Grid>
            </Border>

            <UniformGrid Columns="3" Rows="4">
                <Button Content="Install / Update" Margin="4" Click="InstallUpdate_OnClick"/>
                <Button Content="Repair Boot Entry" Margin="4" Click="RepairBootEntry_OnClick"/>
                <Button Content="Make HackBGRT-Animated Default" Margin="4" Click="MakeDefault_OnClick"/>
                <Button Content="Restore Windows Boot Manager First" Margin="4" Click="RestoreWindowsFirst_OnClick"/>
                <Button Content="Disable" Margin="4" Click="Disable_OnClick"/>
                <Button Content="Uninstall" Margin="4" Click="Uninstall_OnClick"/>
                <Button Content="Restart as Administrator" Margin="4" Click="RestartAdmin_OnClick"/>
                <Button Content="Restart PC" Margin="4" Click="RestartPc_OnClick"/>
                <Button Content="Open App Data Folder" Margin="4" Click="OpenAppData_OnClick"/>
                <Button Content="Open Themes Folder" Margin="4" Click="OpenThemes_OnClick"/>
                <Button Content="Refresh" Margin="4" Click="Refresh_OnClick"/>
            </UniformGrid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
