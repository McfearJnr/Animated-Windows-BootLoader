<UserControl x:Class="HackBGRTAnimated.UI.Views.LogsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Logs" FontSize="30" FontWeight="Bold"/>
            <TextBlock x:Name="LogsPathText" Margin="0,4,0,12" TextWrapping="Wrap"/>
        </StackPanel>

        <TabControl Grid.Row="1" Margin="0,12,0,12">
            <TabItem Header="Boot Log">
                <TextBox x:Name="BootLogBox" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" IsReadOnly="True"/>
            </TabItem>
            <TabItem Header="Setup Log">
                <TextBox x:Name="SetupLogBox" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" IsReadOnly="True"/>
            </TabItem>
            <TabItem Header="Action Log">
                <TextBox x:Name="ActionLogBox" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" IsReadOnly="True"/>
            </TabItem>
            <TabItem Header="GUI Log">
                <TextBox x:Name="GuiLogBox" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" IsReadOnly="True"/>
            </TabItem>
        </TabControl>

        <WrapPanel Grid.Row="2">
            <Button Content="Refresh" Width="120" Margin="0,0,8,0" Click="Refresh_OnClick"/>
            <Button Content="Open Logs Folder" Width="160" Click="OpenLogs_OnClick"/>
        </WrapPanel>
    </Grid>
</UserControl>
