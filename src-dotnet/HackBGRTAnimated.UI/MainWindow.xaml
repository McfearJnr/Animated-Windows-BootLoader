<Window x:Class="HackBGRTAnimated.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HackBGRT-Animated Manager" Height="760" Width="1200" MinHeight="680" MinWidth="980"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="#111827" Grid.Column="0">
            <DockPanel Margin="14">
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="HackBGRT-Animated" FontSize="22" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Desktop Setup UI" Foreground="#9CA3AF" Margin="0,4,0,16"/>
                </StackPanel>
                <ListBox x:Name="NavList" Background="Transparent" BorderThickness="0" Foreground="White"
                         SelectionChanged="NavList_OnSelectionChanged">
                    <ListBoxItem Content="Dashboard" Tag="dashboard"/>
                    <ListBoxItem Content="Themes" Tag="themes"/>
                    <ListBoxItem Content="Import GIF" Tag="import"/>
                    <ListBoxItem Content="Boot Order" Tag="boot"/>
                    <ListBoxItem Content="Config" Tag="config"/>
                    <ListBoxItem Content="Logs" Tag="logs"/>
                    <ListBoxItem Content="Advanced" Tag="advanced"/>
                </ListBox>
            </DockPanel>
        </Border>

        <Border Grid.Column="1" Background="#F3F4F6" Padding="16">
            <ContentControl x:Name="PageHost"/>
        </Border>
    </Grid>
</Window>
