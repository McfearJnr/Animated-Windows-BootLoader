<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="PrimaryActionButtonStyle" TargetType="Button">
        <Setter Property="MinHeight" Value="36"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Background" Value="{StaticResource AppPrimaryBrush}"/>
        <Setter Property="Foreground" Value="White"/>
    </Style>

    <Style x:Key="SecondaryActionButtonStyle" TargetType="Button">
        <Setter Property="MinHeight" Value="36"/>
        <Setter Property="Padding" Value="14,8"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Background" Value="{StaticResource AppSurfaceAltBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource AppStrokeBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style x:Key="GhostActionButtonStyle" TargetType="Button">
        <Setter Property="MinHeight" Value="34"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Background" Value="#00FFFFFF"/>
        <Setter Property="BorderBrush" Value="{StaticResource AppStrokeBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>
</ResourceDictionary>
