<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="AppCardBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource AppSurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource AppStrokeBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource AppCardCornerRadius}"/>
        <Setter Property="Padding" Value="16"/>
    </Style>

    <Style x:Key="AppCardMutedBorderStyle" TargetType="Border" BasedOn="{StaticResource AppCardBorderStyle}">
        <Setter Property="Background" Value="{StaticResource AppSurfaceAltBrush}"/>
    </Style>

    <Style x:Key="PillBorderStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="{StaticResource AppPillCornerRadius}"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="BorderBrush" Value="{StaticResource AppStrokeBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Background" Value="#14000000"/>
    </Style>
</ResourceDictionary>
