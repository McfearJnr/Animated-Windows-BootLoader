<UserControl
    x:Class="HackBGRTAnimated.WinUI.Controls.EmptyState"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    x:Name="Root">

    <Border Style="{StaticResource AppCardBorderStyle}">
        <StackPanel Spacing="10" HorizontalAlignment="Center" VerticalAlignment="Center">
            <FontIcon Glyph="{Binding IconGlyph, ElementName=Root}" FontSize="28" Foreground="{StaticResource AppSecondaryBrush}" HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding Title, ElementName=Root}" FontSize="20" FontWeight="SemiBold" HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding Message, ElementName=Root}" Style="{StaticResource MutedTextStyle}" TextAlignment="Center"/>
        </StackPanel>
    </Border>
</UserControl>
