<UserControl
    x:Class="HackBGRTAnimated.WinUI.Controls.StatusCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    x:Name="Root">

    <Border Style="{StaticResource AppCardBorderStyle}">
        <StackPanel Spacing="8">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <FontIcon Glyph="{Binding IconGlyph, ElementName=Root}" Foreground="{Binding AccentBrush, ElementName=Root}" FontSize="16"/>
                <TextBlock Text="{Binding Title, ElementName=Root}" Style="{StaticResource MutedTextStyle}"/>
            </StackPanel>

            <TextBlock Text="{Binding Value, ElementName=Root}" FontSize="22" FontWeight="SemiBold" TextWrapping="Wrap"/>
            <TextBlock Text="{Binding Description, ElementName=Root}" Style="{StaticResource MutedTextStyle}"/>
        </StackPanel>
    </Border>
</UserControl>
