<Page
    x:Class="HackBGRTAnimated.WinUI.Views.ThemesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:HackBGRTAnimated.WinUI.Controls"
    mc:Ignorable="d"
    Background="{StaticResource AppBackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="20,20,20,12" Style="{StaticResource AppCardBorderStyle}" Background="{StaticResource AppSurfaceAltBrush}">
            <StackPanel Spacing="6">
                <TextBlock Text="Themes" Style="{StaticResource PageTitleTextStyle}"/>
                <TextBlock x:Name="ActiveThemeText" Style="{StaticResource HeroSubHeadingTextStyle}"/>
                <TextBlock x:Name="ThemeCountText" Style="{StaticResource MutedTextStyle}"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="20,0,20,0">
            <ListView x:Name="ThemesList" SelectionMode="Single">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <controls:ThemeCard
                            Margin="0,0,0,10"
                            Title="{Binding Name}"
                            Subtitle="{Binding SizeText}"
                            Timing="{Binding TimingText}"
                            Stats="{Binding FrameCountText}"
                            IsActive="{Binding IsActive}"
                            ActiveBadgeVisibility="{Binding ActiveBadgeVisibility}"
                            PreviewImage="{Binding PreviewImage}"/>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <controls:EmptyState x:Name="ThemesEmptyState"
                                 Visibility="Collapsed"
                                 Title="No themes found"
                                 Message="Import your first GIF theme to get started."
                                 IconGlyph="&#xE7F4;"/>
        </Grid>

        <Border Grid.Row="2" Margin="20,10,20,20" Style="{StaticResource AppCardBorderStyle}">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Button Content="Refresh" Style="{StaticResource SecondaryActionButtonStyle}" Click="Refresh_OnClick"/>
                <Button Content="Set Active" Style="{StaticResource PrimaryActionButtonStyle}" Click="SetActive_OnClick"/>
                <Button Content="Edit" Style="{StaticResource GhostActionButtonStyle}" Click="EditTiming_OnClick"/>
                <Button Content="Preview" Style="{StaticResource GhostActionButtonStyle}" Click="Preview_OnClick"/>
                <Button Content="Delete" Style="{StaticResource GhostActionButtonStyle}" Click="DeleteTheme_OnClick"/>
                <Button Content="Open Folder" Style="{StaticResource GhostActionButtonStyle}" Click="OpenFolder_OnClick"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
