<Page
    x:Class="HackBGRTAnimated.WinUI.Views.OobePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FF0B132B" Offset="0.0"/>
                <GradientStop Color="#FF1C2541" Offset="0.45"/>
                <GradientStop Color="#FF3A86FF" Offset="0.75"/>
                <GradientStop Color="#FF00C2FF" Offset="1.0"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Margin="28,24,28,16" Spacing="6">
                <TextBlock Text="Hello." FontSize="44" FontWeight="SemiBold"/>
                <TextBlock Text="Welcome to HackBGRT-Animated." FontSize="26"/>
                <TextBlock Text="Your EFI is the limit." Opacity="0.85"/>
                <TextBlock x:Name="StepHeaderText" Margin="0,10,0,0" FontSize="20" FontWeight="SemiBold"/>
                <TextBlock x:Name="StepDescriptionText" Opacity="0.8" TextWrapping="Wrap"/>
            </StackPanel>

            <Border Grid.Row="1" Margin="28,0,28,20" Padding="16" CornerRadius="14" Background="#1AFFFFFF">
                <ScrollViewer>
                    <StackPanel Spacing="14">
                        <StackPanel x:Name="StepWelcomePanel" Spacing="8">
                            <TextBlock Text="This first-run setup will check safety status, install or repair HackBGRT-Animated, and help you choose your first theme and boot behavior." TextWrapping="Wrap"/>
                            <TextBlock Text="No online account, telemetry, or cloud services are used." Opacity="0.85" TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel x:Name="StepDisplayNamePanel" Spacing="8" Visibility="Collapsed">
                            <TextBlock Text="Choose a display name (local only):"/>
                            <TextBox x:Name="DisplayNameBox" PlaceholderText="Nickname" Width="320"/>
                        </StackPanel>

                        <StackPanel x:Name="StepSafetyPanel" Spacing="6" Visibility="Collapsed">
                            <TextBlock x:Name="SafetyAdminText"/>
                            <TextBlock x:Name="SafetyEfiText"/>
                            <TextBlock x:Name="SafetyWindowsText"/>
                            <TextBlock x:Name="SafetyHackBgrtText"/>
                            <TextBlock x:Name="SafetyAnimatedText"/>
                            <TextBlock Text="BitLocker reminder: if your system uses BitLocker, keep recovery information available before changing firmware boot entries." TextWrapping="Wrap" Opacity="0.85"/>
                        </StackPanel>

                        <StackPanel x:Name="StepInstallPanel" Spacing="8" Visibility="Collapsed">
                            <TextBlock Text="Install or repair HackBGRT-Animated now:"/>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Button x:Name="InstallRepairButton" Content="Install / Repair" Click="InstallRepairButton_OnClick"/>
                                <Button Content="Refresh Status" Click="RefreshSafetyButton_OnClick"/>
                            </StackPanel>
                            <TextBlock x:Name="InstallStatusText" Opacity="0.9" TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel x:Name="StepThemePanel" Spacing="8" Visibility="Collapsed">
                            <TextBlock Text="Choose your first active theme:"/>
                            <ComboBox x:Name="ThemeCombo" Width="360"/>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Button Content="Set Active" Click="SetActiveThemeButton_OnClick"/>
                                <Button Content="Refresh Themes" Click="RefreshThemesButton_OnClick"/>
                            </StackPanel>
                            <TextBlock Text="You can import GIF themes from the Import GIF page after setup." Opacity="0.85" TextWrapping="Wrap"/>
                            <TextBlock x:Name="ThemeStatusText" Opacity="0.9" TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel x:Name="StepBootPanel" Spacing="8" Visibility="Collapsed">
                            <TextBlock Text="Choose boot behavior:"/>
                            <RadioButton x:Name="BootKeepOrderRadio" Content="Keep current boot order and add as selectable option" IsChecked="True"/>
                            <RadioButton x:Name="BootAnimatedFirstRadio" Content="Put HackBGRT-Animated first"/>
                            <RadioButton x:Name="BootWindowsFirstRadio" Content="Restore Windows Boot Manager first"/>
                            <TextBlock Text="Boot order changes affect firmware display order only." Opacity="0.85" TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel x:Name="StepFinishPanel" Spacing="8" Visibility="Collapsed">
                            <TextBlock Text="Setup summary" FontWeight="SemiBold"/>
                            <TextBox x:Name="SummaryBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" Height="180" ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Grid Grid.Row="2" Margin="28,0,28,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="FooterText" VerticalAlignment="Center" Opacity="0.8" Text="Step 1 of 7"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                    <Button x:Name="BackButton" Content="Back" Click="BackButton_OnClick" IsEnabled="False"/>
                    <Button x:Name="NextButton" Content="Next" Click="NextButton_OnClick"/>
                    <Button x:Name="FinishButton" Content="Finish" Click="FinishButton_OnClick" Visibility="Collapsed"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Page>
