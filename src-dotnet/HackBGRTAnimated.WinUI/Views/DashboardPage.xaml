<Page
    x:Class="HackBGRTAnimated.WinUI.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:HackBGRTAnimated.WinUI.Controls"
    mc:Ignorable="d"
    Background="{StaticResource AppBackgroundBrush}">

    <ScrollViewer>
        <StackPanel Spacing="16" Padding="20,20,20,28">
            <Border Style="{StaticResource AppCardBorderStyle}" Background="{StaticResource AppSurfaceAltBrush}">
                <StackPanel Spacing="6">
                    <TextBlock Text="Dashboard" Style="{StaticResource PageTitleTextStyle}"/>
                    <TextBlock Text="Welcome back." Style="{StaticResource HeroSubHeadingTextStyle}"/>
                    <TextBlock Text="{Binding GreetingName}" Style="{StaticResource MutedTextStyle}"/>
                    <TextBlock Text="HackBGRT-Animated system health overview" Style="{StaticResource MutedTextStyle}"/>
                </StackPanel>
            </Border>

            <InfoBar x:Name="AdminInfoBar"
                     Severity="Warning"
                     IsOpen="False"
                     IsClosable="False"
                     Title="Administrator rights are required for boot-entry operations."
                     Message="Theme editing and previews can run without admin, but install/repair/boot operations require elevation.">
                <InfoBar.ActionButton>
                    <Button Content="Restart as Administrator" Style="{StaticResource SecondaryActionButtonStyle}" Click="RestartAdminButton_OnClick" />
                </InfoBar.ActionButton>
            </InfoBar>

            <Grid ColumnSpacing="12" RowSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <controls:StatusCard Grid.Row="0" Grid.Column="0"
                                     Title="Installed"
                                     Value="{Binding Installed}"
                                     Description="{Binding InstalledDetail}"
                                     IconGlyph="&#xE73E;"
                                     AccentBrush="{StaticResource AppSuccessBrush}"/>

                <controls:StatusCard Grid.Row="0" Grid.Column="1"
                                     Title="Boot Entry"
                                     Value="{Binding BootEntry}"
                                     Description="{Binding BootEntryDetail}"
                                     IconGlyph="&#xE7AD;"
                                     AccentBrush="{StaticResource AppSecondaryBrush}"/>

                <controls:StatusCard Grid.Row="0" Grid.Column="2"
                                     Title="Active Theme"
                                     Value="{Binding ActiveTheme}"
                                     Description="{Binding ActiveThemeDetail}"
                                     IconGlyph="&#xE790;"
                                     AccentBrush="{StaticResource AppPrimaryBrush}"/>

                <controls:StatusCard Grid.Row="1" Grid.Column="0"
                                     Title="Boot Order"
                                     Value="{Binding BootOrder}"
                                     Description="{Binding BootOrderDetail}"
                                     IconGlyph="&#xE8D2;"
                                     AccentBrush="{StaticResource AppWarningBrush}"/>

                <controls:StatusCard Grid.Row="1" Grid.Column="1"
                                     Title="Admin"
                                     Value="{Binding AdminState}"
                                     Description="{Binding AdminDetail}"
                                     IconGlyph="&#xE946;"
                                     AccentBrush="{StaticResource AppDangerBrush}"/>

                <controls:StatusCard Grid.Row="1" Grid.Column="2"
                                     Title="EFI Folder"
                                     Value="{Binding EfiFolder}"
                                     Description="{Binding EfiFolderDetail}"
                                     IconGlyph="&#xED43;"
                                     AccentBrush="{StaticResource AppSecondaryBrush}"/>
            </Grid>

            <Border Style="{StaticResource AppCardBorderStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Primary Actions" Style="{StaticResource SectionTitleTextStyle}"/>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Content="Install / Update" Style="{StaticResource PrimaryActionButtonStyle}" Click="InstallOrUpdate_OnClick" />
                        <Button Content="Repair Boot Entry" Style="{StaticResource SecondaryActionButtonStyle}" Click="RepairBootEntry_OnClick" />
                        <Button Content="Refresh Status" Style="{StaticResource GhostActionButtonStyle}" Click="Refresh_OnClick" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource AppCardBorderStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Secondary Actions" Style="{StaticResource SectionTitleTextStyle}"/>
                    <TextBlock Text="Use these only when you specifically need to adjust boot priority or disable/uninstall." Style="{StaticResource MutedTextStyle}"/>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Content="Make HackBGRT-Animated Default" Style="{StaticResource GhostActionButtonStyle}" Click="MakeDefault_OnClick" />
                        <Button Content="Restore Windows Boot Manager First" Style="{StaticResource GhostActionButtonStyle}" Click="RestoreWindowsFirst_OnClick" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Content="Disable" Style="{StaticResource GhostActionButtonStyle}" Click="Disable_OnClick" />
                        <Button Content="Uninstall" Style="{StaticResource GhostActionButtonStyle}" Click="Uninstall_OnClick" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource AppCardMutedBorderStyle}">
                <StackPanel Spacing="4">
                    <TextBlock Text="Local AppData Root" Style="{StaticResource MutedTextStyle}"/>
                    <TextBlock Text="{Binding AppDataRoot}" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
